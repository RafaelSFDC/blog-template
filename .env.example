# Database Configuration (Universal Adapter)
# Types: sqlite | d1 | neon | libsql
DB_TYPE=sqlite
DATABASE_URL=blog.db
DATABASE_AUTH_TOKEN=your_auth_token_for_libsql_turso

# Cloudflare Credentials (Only for Drizzle migrations/studio)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_DATABASE_ID=4b5ad0b3-fea9-46fe-8b32-aed3d396f217
CLOUDFLARE_D1_TOKEN=your_api_token_with_d1_permissions

# App Config
CLOUDFLARE_ANALYTICS_TOKEN=your_analytics_token
BETTER_AUTH_SECRET=your_auth_secret
BETTER_AUTH_URL=http://localhost:3000

# Better-Auth Social Providers (Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 Storage
# Production on Cloudflare should prefer the `STORAGE` binding from wrangler.jsonc.
# The credentials below are optional and only needed if you want to validate R2
# through the S3-compatible API outside the Worker binding.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_PUBLIC_URL= # e.g., https://media.yourdomain.com or an R2.dev URL

# Scheduled publishing
# Used only for manually triggering /api/cron/publish.
# Native Cloudflare Cron Triggers do not require this secret.
CRON_SECRET=

# PostHog Analytics
VITE_POSTHOG_KEY=your_posthog_project_api_key
VITE_POSTHOG_HOST=https://app.posthog.com # Or https://eu.posthog.com
VITE_POSTHOG_PROJECT_ID=your_project_id
POSTHOG_PERSONAL_API_KEY=your_personal_api_key_for_backend_queries
