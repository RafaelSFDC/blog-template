# Database Configuration
# Local development and tests are SQLite-only.
DATABASE_URL=blog.db

# Cloudflare Credentials (production operations only)
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_DATABASE_ID=4b5ad0b3-fea9-46fe-8b32-aed3d396f217
CLOUDFLARE_D1_TOKEN=your_api_token_with_d1_permissions

# App Config
CLOUDFLARE_ANALYTICS_TOKEN=your_analytics_token
BETTER_AUTH_SECRET=your_auth_secret
BETTER_AUTH_URL=http://localhost:3000
APP_URL=http://localhost:3000
ENVIRONMENT=development

# Better-Auth Social Providers (Optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare R2 Storage
# Production on Cloudflare should use the `STORAGE` binding from wrangler.jsonc.
# Local development and tests always write uploads to `public/uploads`.
R2_PUBLIC_URL= # optional CDN/public bucket URL for production media links

# Scheduled publishing
# Used only for manually triggering /api/cron/publish.
# Native Cloudflare Cron Triggers do not require this secret.
CRON_SECRET=

# PostHog Analytics
VITE_PUBLIC_POSTHOG_KEY=your_posthog_project_api_key
VITE_PUBLIC_POSTHOG_HOST=https://app.posthog.com # Or https://eu.posthog.com
POSTHOG_PERSONAL_API_KEY=your_personal_api_key_for_backend_queries

# Sentry Observability
VITE_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_RELEASE=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SECURITY_CONTACT_EMAIL=

# Webhooks
RESEND_WEBHOOK_SECRET=
