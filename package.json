{
  "name": "lumina-blog",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:cf": "wrangler dev --port 3000",
    "dev:cf:scheduled": "wrangler dev --test-scheduled --port 3000",
    "build": "node --max-old-space-size=4096 ./node_modules/vite/bin/vite.js build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "pnpm run test:unit && pnpm run test:integration",
    "test:unit": "vitest run src",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/e2e/smoke.spec.ts",
    "check:actions-location": "tsx scripts/check-actions-location.ts",
    "lint": "pnpm run check:actions-location && eslint .",
    "lint:fix": "eslint . --fix",
    "deploy": "pnpm run db:migrate:prod && pnpm run build && wrangler deploy",
    "db:migrate": "tsx db/migrate.ts",
    "db:migrate:prod": "tsx db/migrate.ts --prod",
    "seed": "tsx seed.ts",
    "seed:fixtures": "tsx scripts/seed-fixtures.ts",
    "seed:cf": "wrangler d1 execute blog-db --local --file=./drizzle/0000_mixed_the_professor.sql && tsx seed.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate:legacy": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "ops:smoke": "tsx scripts/ops/smoke-check.ts",
    "ops:backup:d1": "tsx scripts/ops/d1-backup.ts",
    "ops:restore:d1": "tsx scripts/ops/d1-restore.ts",
    "ops:restore:time-travel": "tsx scripts/ops/d1-time-travel-restore.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@base-ui/react": "^1.2.0",
    "@cloudflare/vite-plugin": "^1.26.0",
    "@faker-js/faker": "^10.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@libsql/client": "^0.17.0",
    "@neondatabase/serverless": "^1.0.2",
    "@neondatabase/vite-plugin-postgres": "^0.7.0",
    "@posthog/react": "^1.8.2",
    "@puckeditor/core": "^0.21.1",
    "@sentry/cloudflare": "^10.43.0",
    "@sentry/react": "^10.43.0",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/query-db-collection": "^1.0.28",
    "@tanstack/react-db": "^0.1.75",
    "@tanstack/react-devtools": "^0.9.10",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-router-devtools": "^1.166.2",
    "@tanstack/react-router-ssr-query": "^1.166.2",
    "@tanstack/react-start": "^1.166.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/zod-form-adapter": "^0.42.1",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-color": "^3.20.1",
    "@tiptap/extension-heading": "^3.20.1",
    "@tiptap/extension-highlight": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/extension-link": "^3.20.1",
    "@tiptap/extension-placeholder": "^3.20.1",
    "@tiptap/extension-subscript": "^3.20.1",
    "@tiptap/extension-superscript": "^3.20.1",
    "@tiptap/extension-text-align": "^3.20.1",
    "@tiptap/extension-text-style": "^3.20.1",
    "@tiptap/extension-typography": "^3.20.1",
    "@tiptap/extension-underline": "^3.20.1",
    "@tiptap/extension-youtube": "^3.20.1",
    "@tiptap/pm": "^3.20.1",
    "@tiptap/react": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "better-auth": "^1.5.3",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "posthog-js": "^1.360.0",
    "posthog-node": "^5.28.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^4.7.2",
    "recharts": "2.15.4",
    "remark-gfm": "^4.0.0",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tiptap-markdown": "^0.9.0",
    "tw-animate-css": "^1.3.6",
    "use-debounce": "^10.1.0",
    "vaul": "^1.1.2",
    "vinxi": "^0.5.11",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@inlang/paraglide-js": "^2.13.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "^0.5.3",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^28.1.0",
    "nitro": "npm:nitro-nightly@latest",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "wrangler": "^4.70.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "better-sqlite3"
    ]
  }
}
